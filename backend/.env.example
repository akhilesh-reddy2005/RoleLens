# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# Upload
MAX_FILE_SIZE_MB=10

# Live jobs module (Remotive + Arbeitnow are free/keyless and always on;
# Adzuna/JSearch are optional — leave blank to disable that provider)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
# Metered (SerpApi free trial then paid) — used only for the on-demand
# "Search with Google Jobs" button, not the background refresh cron.
SERPAPI_KEY=
JSEARCH_RAPIDAPI_KEY=
JOB_REFRESH_CRON=*/20 * * * *
JOB_MATCH_NOTIFY_THRESHOLD=60
